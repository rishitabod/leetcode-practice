class Solution {
    public boolean isPerfectSquare(int num) {
        long low =1;
        long high = num;
        if(num ==1){
            return true;
        }

        while(low <= high){
            long mid = (low + high)/2 ;

            if(mid * mid == num){
                return true;
            }else if(mid*mid < num){
                low = (int)mid +1;
            }else{
                high =(int)mid -1;
            }
        }
        return false;
    }
}
