class Solution {
    public int minimumDeletions(int[] nums) {
        int n = nums.length;
        int minIdx=0;
        int maxIdx =0;
        int mini = Integer.MAX_VALUE;
        int maxi = Integer.MIN_VALUE;
        for(int i=0;i<nums.length;i++){
            if(nums[i] > maxi){
                maxi = nums[i];
                maxIdx = i;
            }
            if(nums[i] < mini){
                mini = nums[i];
                minIdx = i;
            }
        }
        int left = Math.max(maxIdx,minIdx)+1;
        int right = n - Math.min(maxIdx,minIdx);
        int split = Math.min(maxIdx,minIdx) + 1 + n - Math.max(minIdx,maxIdx);

        return Math.min(left,Math.min(right,split));
    }
}
