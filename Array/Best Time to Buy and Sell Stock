class Solution {
    public int maxProfit(int[] prices) {
        int minP = prices[0];
        int profit = 0;

        for (int i = 1; i < prices.length; i++) {
            int diff = prices[i] - minP;
            profit = Math.max(profit, diff);
            minP = Math.min(minP, prices[i]);
        }

        return profit;
    }
}
